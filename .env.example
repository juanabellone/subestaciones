# Supabase (solo base de datos)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# Auth — firma de cookies de sesión (inventate una clave larga y random)
AUTH_SECRET=una_clave_secreta_larga_aqui

# Credenciales de acceso
ADMIN_EMAIL=admin@ejemplo.com
ADMIN_PASSWORD=contraseña_admin

CLIENT_EMAIL=cliente@ejemplo.com
CLIENT_PASSWORD=contraseña_cliente
